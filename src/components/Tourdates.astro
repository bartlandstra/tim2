---
import data from '../data/tourdates.json';
const shows = data.shows;

function formatDate(dateString: string): string {
  const date = new Date(dateString + 'T12:00:00');
  const dayNames = ['zo', 'ma', 'di', 'wo', 'do', 'vr', 'za'];
  const monthNames = ['januari', 'februari', 'maart', 'april', 'mei', 'juni', 'juli', 'augustus', 'september', 'oktober', 'november', 'december'];
  return `${dayNames[date.getDay()]} ${date.getDate()} ${monthNames[date.getMonth()]}`;
}
---

<section id="tourdates" class="py-24 md:py-32 px-6 md:px-12" style="background: var(--color-bg);">
  <div class="max-w-4xl mx-auto">
    <div class="section-ornament mb-8">
      <span>Tourdates</span>
    </div>
    <h2 class="text-4xl md:text-5xl text-center mb-4" style="color: var(--color-cream); font-family: var(--font-display);">
      Aankomende Shows
    </h2>
    <p class="text-center mb-16" style="color: var(--color-text-muted); font-family: var(--font-body);">
      Bekijk waar Tim binnenkort speelt.
    </p>

    <!-- No shows message -->
    <div id="no-shows" class="hidden text-center py-16">
      <p style="color: var(--color-text-muted); font-family: var(--font-body); font-size: 1.1rem;">
        Er zijn momenteel geen geplande optredens.<br />
        <a href="#contact" style="color: var(--color-accent); border-bottom: 1px solid var(--color-accent);">Neem contact op</a> voor boekingen.
      </p>
    </div>

    <div id="shows-list" class="space-y-0">
      {shows.map((show, index) => (
        <div
          class="show-row"
          data-date={show.date}
          style="display: grid; grid-template-columns: 140px 1fr auto; gap: 1.5rem; align-items: center; padding: 1.5rem 0;"
        >
          <!-- Date -->
          <div class="mono-label" style="font-size: 0.8rem;">
            {formatDate(show.date)}
          </div>

          <!-- Venue & Act -->
          <div>
            <div style="font-family: var(--font-body); color: var(--color-text); font-weight: 600;">
              {show.venue} <span style="color: var(--color-text-muted); font-weight: 400;">— {show.city}</span>
            </div>
            <div style="font-family: var(--font-body); color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem;">
              {show.act}
            </div>
          </div>

          <!-- Ticket button -->
          <div>
            {show.url ? (
              <a href={show.url} target="_blank" rel="noopener" class="btn-warm" style="padding: 0.6rem 1.5rem; font-size: 0.7rem;">
                Tickets
              </a>
            ) : (
              <span class="btn-outline-warm" style="padding: 0.6rem 1.5rem; font-size: 0.7rem; opacity: 0.6;">
                Binnenkort
              </span>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="warm-divider mt-8 mb-8"></div>

    <div class="text-center">
      <p style="color: var(--color-text-muted); font-family: var(--font-body); font-size: 0.95rem;">
        Wil je Tim boeken voor jouw evenement?
        <a href="#contact" style="color: var(--color-accent); border-bottom: 1px solid var(--color-accent-dim); transition: border-color 0.3s;">Neem contact op</a>
      </p>
    </div>
  </div>
</section>

<style>
  .show-row + .show-row {
    border-top: 1px solid rgba(196, 113, 59, 0.12);
  }

  .show-row:hover {
    background: var(--color-surface);
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: 4px;
  }

  @media (max-width: 640px) {
    .show-row {
      grid-template-columns: 1fr !important;
      gap: 0.5rem !important;
    }
  }
</style>

<script>
  function hidePastShows() {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const rows = document.querySelectorAll('.show-row');
    let visibleCount = 0;

    rows.forEach(row => {
      const dateStr = (row as HTMLElement).dataset.date;
      if (dateStr) {
        const showDate = new Date(dateStr + 'T23:59:59');
        if (showDate < today) {
          (row as HTMLElement).style.display = 'none';
        } else {
          visibleCount++;
        }
      }
    });

    if (visibleCount === 0) {
      document.getElementById('no-shows')?.classList.remove('hidden');
      document.getElementById('shows-list')?.classList.add('hidden');
    }
  }

  hidePastShows();
</script>
