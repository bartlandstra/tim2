---
const year = new Date().getFullYear();
---

<footer class="py-8 px-6 md:px-12 border-t" style="border-color: var(--color-surface);">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="text-sm" style="color: var(--color-text-muted);">
      &copy; {year} Tim Eijmaal. Alle rechten voorbehouden.
    </div>
    <div class="flex items-center gap-6">
      <a href="#" class="text-sm transition-colors duration-300 hover:text-[var(--color-accent)]" style="color: var(--color-text-muted);">
        Privacy
      </a>
      <span style="color: var(--color-surface);">|</span>
      <a href="#" class="text-sm transition-colors duration-300 hover:text-[var(--color-accent)]" style="color: var(--color-text-muted);">
        Colofon
      </a>
    </div>
  </div>
</footer>
