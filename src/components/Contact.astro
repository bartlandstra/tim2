---

<section id="contact" class="contact-section">
  <div class="contact-container">
    <div class="contact-grid">
      <!-- Left: Info -->
      <div class="contact-left">
        <div class="section-ornament">
          <h2>Contact & Booking</h2>
        </div>

        <p class="contact-description">
          Voor boekingen, studio sessies, arrangementen en producties ben ik beschikbaar.
          Tim werkt samen met artiesten aan live-optredens, studiowerk en custom arrangementen.
        </p>

        <!-- Services -->
        <div class="services-list">
          <div class="service-item">
            <span>Studio sessions & remote recording</span>
          </div>
          <div class="service-item">
            <span>Live optredens & tours</span>
          </div>
          <div class="service-item">
            <span>Arrangement & productie</span>
          </div>
          <div class="service-item">
            <span>Gitaarlessen</span>
          </div>
        </div>

        <!-- Socials -->
        <div class="socials-container">
          {socials.map(social => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.name}
              class="social-icon"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="contact-right">
        <form name="contact" method="POST" class="contact-form" action="#">
          <div class="form-group">
            <label for="name" class="form-label">Naam</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">E-mail</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label for="subject" class="form-label">Onderwerp</label>
            <select id="subject" name="subject" class="form-input">
              <option value="">Selecteer een onderwerp</option>
              <option value="booking">Booking & live</option>
              <option value="session">Studio / session werk</option>
              <option value="arrangement">Arrangement / productie</option>
              <option value="lessons">Gitaarlessen</option>
              <option value="other">Overig</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Bericht</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="form-input"
            ></textarea>
          </div>

          <button type="submit" class="btn-warm submit-btn">Verstuur bericht</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background-color: var(--color-surface);
    padding: 4rem 2rem;
    color: var(--color-text);
  }

  .contact-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .section-ornament h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 400;
    margin-bottom: 2rem;
    color: var(--color-accent);
  }

  .contact-description {
    font-family: 'Libre Baskerville', serif;
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .service-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    color: var(--color-text);
    padding-left: 1.5rem;
    position: relative;
  }

  .service-item::before {
    content: '';
    position: absolute;
    left: 0;
    width: 0.5rem;
    height: 0.5rem;
    background-color: var(--color-accent);
  }

  .socials-container {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--color-bg);
    color: var(--color-accent);
    border-radius: 50%;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-icon:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .form-input {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    padding: 0.8rem 1rem;
    background-color: var(--color-bg);
    border: 1px solid #3a3024;
    color: var(--color-text);
    transition: border-color 0.3s ease;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .submit-btn {
    margin-top: 1rem;
    padding: 1rem;
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .section-ornament h2 {
      font-size: 2rem;
    }
  }
</style>
