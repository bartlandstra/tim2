---

<section id="contact" class="py-24 md:py-32 px-6 md:px-12" style="background: var(--color-surface);">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16">
      <!-- Left: Info -->
      <div>
        <div class="section-line mb-6"></div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
          Contact & <span style="color: var(--color-accent);">Booking</span>
        </h2>

        <p class="leading-relaxed mb-8" style="color: var(--color-text-muted);">
          Voor boekingen, session werk, producties of samenwerkingen — neem gerust contact op.
          Tim is beschikbaar voor studio-sessies, live-optredens, arrangementen en producties.
        </p>

        <!-- Services -->
        <div class="space-y-4 mb-10">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full" style="background: var(--color-accent);"></div>
            <span>Studio sessions & remote recording</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full" style="background: var(--color-accent);"></div>
            <span>Live optredens & tours</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full" style="background: var(--color-accent);"></div>
            <span>Arrangement & productie</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full" style="background: var(--color-accent);"></div>
            <span>Gitaarlessen (jazz, blues, pop, rock)</span>
          </div>
        </div>

        <!-- Socials -->
        <div class="flex gap-4">
          {socials.map(social => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener"
              aria-label={social.name}
              class="w-10 h-10 flex items-center justify-center rounded-full transition-all duration-300 hover:scale-110"
              style="background: var(--color-bg);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="color: var(--color-text-muted);">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div>
        <form
          name="contact"
          method="POST"
          class="space-y-5"
          data-netlify="false"
          action="#"
        >
          <div>
            <label for="name" class="block text-sm uppercase tracking-wide mb-2" style="color: var(--color-text-muted);">Naam</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 text-white outline-none transition-colors duration-300 focus:border-[var(--color-accent)]"
              style="background: var(--color-bg); border: 1px solid #333;"
            />
          </div>

          <div>
            <label for="email" class="block text-sm uppercase tracking-wide mb-2" style="color: var(--color-text-muted);">E-mail</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 text-white outline-none transition-colors duration-300 focus:border-[var(--color-accent)]"
              style="background: var(--color-bg); border: 1px solid #333;"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm uppercase tracking-wide mb-2" style="color: var(--color-text-muted);">Onderwerp</label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 text-white outline-none transition-colors duration-300 focus:border-[var(--color-accent)]"
              style="background: var(--color-bg); border: 1px solid #333;"
            >
              <option value="booking">Booking & live</option>
              <option value="session">Studio / session werk</option>
              <option value="productie">Arrangement / productie</option>
              <option value="les">Gitaarlessen</option>
              <option value="overig">Overig</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm uppercase tracking-wide mb-2" style="color: var(--color-text-muted);">Bericht</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 text-white outline-none transition-colors duration-300 resize-none focus:border-[var(--color-accent)]"
              style="background: var(--color-bg); border: 1px solid #333;"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-4 text-sm font-medium tracking-wide uppercase transition-all duration-300 hover:scale-[1.02]"
            style="background: var(--color-accent); color: var(--color-bg);"
          >
            Verstuur bericht
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
