---
---

<section class="relative h-screen w-full overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/tim-hero.jpg"
      alt="Tim Eijmaal met gitaar"
      class="w-full h-full object-cover object-center"
      loading="eager"
    />
    <!-- Gradients overlay -->
    <div class="hero-gradient absolute inset-0"></div>
    <div class="hero-gradient-left absolute inset-0"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 h-full flex flex-col justify-end pb-24 md:pb-32 px-6 md:px-12 max-w-6xl mx-auto">
    <div class="section-line animate-fade-in-up mb-6"></div>

    <h1 class="animate-fade-in-up delay-100 text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-none mb-4">
      Tim<br />
      <span style="color: var(--color-accent);">Eijmaal</span>
    </h1>

    <p class="animate-fade-in-up delay-200 text-lg md:text-xl max-w-md leading-relaxed" style="color: var(--color-text-muted);">
      Gitarist · Session musician · Producer
    </p>

    <div class="animate-fade-in-up delay-300 flex flex-wrap gap-4 mt-8">
      <a
        href="#muziek"
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium tracking-wide uppercase transition-all duration-300 hover:scale-105"
        style="background: var(--color-accent); color: var(--color-bg);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Luister
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium tracking-wide uppercase border transition-all duration-300 hover:bg-white/10"
        style="border-color: var(--color-text-muted); color: var(--color-text);"
      >
        Booking & Contact
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in delay-600">
    <div class="flex flex-col items-center gap-2" style="color: var(--color-text-muted);">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <div class="w-px h-8 bg-white/20 relative overflow-hidden">
        <div class="w-full h-1/2 animate-bounce" style="background: var(--color-accent);"></div>
      </div>
    </div>
  </div>
</section>
